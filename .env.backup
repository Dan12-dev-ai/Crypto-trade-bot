# UOTA Elite v2 - Environment Variables Template
# Copy this file to .env and fill in your actual credentials

# Exchange API Credentials (fill in the exchanges you want to use)
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_API_SECRET=your_binance_api_secret_here

BYBIT_API_KEY=your_bybit_api_key_here
BYBIT_API_SECRET=your_bybit_api_secret_here

OKX_API_KEY=your_okx_api_key_here
OKX_API_SECRET=your_okx_api_secret_here
OKX_PASSPHRASE=your_okx_passphrase_here

HYPERLIQUID_API_KEY=your_hyperliquid_api_key_here
HYPERLIQUID_API_SECRET=your_hyperliquid_api_secret_here

GATE_API_KEY=your_gate_api_key_here
GATE_API_SECRET=your_gate_api_secret_here

# Forex Brokers
OANDA_API_KEY=your_oanda_api_key_here
OANDA_API_SECRET=your_oanda_api_key_here

ICMARKETS_API_KEY=your_icmarkets_api_key_here
ICMARKETS_API_SECRET=your_icmarkets_api_secret_here

PEPPERSTONE_API_KEY=your_pepperstone_api_key_here
PEPPERSTONE_API_SECRET=your_pepperstone_api_secret_here

# Exness MT5 Configuration
EXNESS_LOGIN=11000575398
EXNESS_PASSWORD=your_exness_password_here
EXNESS_SERVER=Exness-MT5Trial10
EXNESS_PATH_WINE=/usr/bin/wine
EXNESS_PATH_MT5=/path/to/mt5/terminal64.exe

# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# Optional: Custom Ollama Configuration
OLLAMA_BASE_URL=http://localhost:11434

# Optional: Custom Database Path
DATABASE_PATH=data/trading_bot.db
